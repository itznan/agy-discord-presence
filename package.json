{
  "name": "@itznan/antigravity-discord-presence",
  "version": "1.0.1",
  "description": "Discord Rich Presence integration for Antigravity CLI",
  "main": "src/discord-presence.js",
  "bin": {
    "discord-presence-uninstall": "scripts/uninstall.js"
  },
  "scripts": {
    "start": "node src/discord-presence.js",
    "hook": "node src/hook-trigger.js",
    "build": "npx esbuild src/discord-presence.js --bundle --platform=node --minify --outfile=dist/discord-presence.js && npx esbuild src/hook-trigger.js --bundle --platform=node --minify --outfile=dist/hook-trigger.js",
    "postinstall": "node scripts/install.js",
    "uninstall": "node scripts/uninstall.js",
    "preuninstall": "node scripts/uninstall.js"
  },
  "devDependencies": {
    "esbuild": "^0.20.0"
  },
  "keywords": [
    "antigravity",
    "discord",
    "rich-presence",
    "sidecar",
    "hook"
  ],
  "author": "itznan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itznan/agy-discord-presence.git"
  },
  "bugs": {
    "url": "https://github.com/itznan/agy-discord-presence/issues"
  },
  "homepage": "https://github.com/itznan/agy-discord-presence#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
